{
  "log": {
    "level": "warn",
    "output": "stderr"
  },
  "inbounds": [
    {
      "type": "naive",
      "tag": "naive-in",
      "network": "tcp",
      "listen": "0.0.0.0",
      "listen_port": 1080,
      "users": [
        {
          "username": "${PROXY_LOGIN}",
          "password": "${PROXY_PASSWORD}"
        }
      ]
    }
  ],
  "outbounds": [
    {
      "type": "direct"
    }
  ]
}